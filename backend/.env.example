# OpenAQ v3 (air quality)
OPENAQ_API_KEY=your_openaq_key
OPENAQ_LAT=52.52
OPENAQ_LON=13.41
OPENAQ_RADIUS=10000

# Meteostat via RapidAPI (climate + weather)
METEOSTAT_API_KEY=your_rapidapi_key
METEOSTAT_HOST=meteostat.p.rapidapi.com
METEOSTAT_LAT=52.52
METEOSTAT_LON=13.41

# CO2 (Our World in Data JSON)
CO2_JSON_URL=https://owid-public.owid.io/data/co2/owid-co2-data.json
CO2_COUNTRIES=Germany,South Africa,Kenya,India

# Crops (World Bank API JSON)
CROPS_COUNTRY=ZAF
CROPS_INDICATOR=AG.YLD.CREL.KG
CROPS_JSON_URL=https://api.worldbank.org/v2/country/ZAF/indicator/AG.YLD.CREL.KG?format=json&per_page=20000
